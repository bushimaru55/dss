# Copy to .env and adjust (never commit .env)
DJANGO_SECRET_KEY=change-me-in-production-use-long-random-string
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,web
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

POSTGRES_DB=dss
POSTGRES_USER=dss
POSTGRES_PASSWORD=dss
POSTGRES_HOST=db
POSTGRES_PORT=5432

REDIS_URL=redis://redis:6379/0

# Local file storage (default). Set USE_S3=1 in prod with S3_* vars per runbooks.
USE_S3=0

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
